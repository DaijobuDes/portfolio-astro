---
import avatar from '../assets/256.png';
---

<div id="container">
    <main class="card" aria-label="Portfolio preview">
        <p class="eyebrow">Portfolio</p>
        <div class="profile">
            {/* src={avatar.src} */}
            <img
            class="avatar"
                src="https://avatars.githubusercontent.com/u/38452446"
                alt="Portrait placeholder"
                width="96"
                height="96"
            />
            <h1>Kate Aubrey Cellan</h1>
        </div>
        <p class="lead">
            Software Developer &bull; Homelabber &bull; Hobbyist Security Researcher &bull;
            Hardware Enthusiast &bull; IoT Tinkerer
        </p>

        <section class="details" aria-label="Profile details">
            <div>
                <span class="label">Focus</span>
                <span class="value">Backend Development, Systems Performance, & Network Engineering</span>
            </div>
            <div>
                <span class="label">Based in</span>
                <span class="value">Cebu, Philippines</span>
            </div>
            <div>
                <span class="label">Available for</span>
                <span class="value">Full-time Opportunities (Remote / Hybrid (Cebu City))</span>
            </div>
        </section>

        <div class="actions">
            <a href="https://www.linkedin.com/in/kate-aubrey-cellan/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href="https://github.com/DaijobuDes" target="_blank" rel="noopener noreferrer" class="secondary">Github</a>
        </div>
    </main>
</div>

<style>
    :global(html, body) {
        margin: 0;
        min-height: 100%;
    }

    #container {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
        background:
            /* Change colors here */
            radial-gradient(circle at top, rgba(255, 255, 255, 0.18), transparent 35%),
            linear-gradient(135deg, #0f172a 0%, #111827 55%, #1f2937 100%);
    }

    .card {
        width: min(100%, 520px);
        padding: 32px;
        border-radius: 24px;
        background: rgba(15, 23, 42, 0.82);
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
        color: #f8fafc;
        backdrop-filter: blur(16px);
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        will-change: transform;
    }

    .card:hover {
        transform: translateY(-4px);
        border-color: rgba(255, 255, 255, 0.2);
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.42);
    }

    .eyebrow {
        margin: 0 0 12px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.78rem;
        color: #93c5fd;
    }

    h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 3.25rem);
        line-height: 1.05;
    }

    .profile {
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .avatar {
        flex: 0 0 auto;
        width: 96px;
        height: 96px;
        object-fit: cover;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.24);
        background: rgba(255, 255, 255, 0.06);
    }

    .lead {
        margin: 16px 0 0;
        color: #cbd5e1;
        font-size: 1.05rem;
        line-height: 1.7;
    }

    .details {
        display: grid;
        gap: 16px;
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .details div {
        display: grid;
        gap: 4px;
    }

    .label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #94a3b8;
    }

    .value {
        font-size: 1rem;
        color: #e2e8f0;
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
    }

    .actions a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 18px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
        transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    }

    .actions a:hover {
        transform: translateY(-1px);
    }

    .actions a:first-child {
        background: #f8fafc;
        color: #0f172a;
    }

    .actions a.secondary {
        border: 1px solid rgba(255, 255, 255, 0.18);
        color: #e2e8f0;
        background: rgba(255, 255, 255, 0.04);
    }

    @media (max-width: 480px) {
        .profile {
            align-items: flex-start;
        }

        .avatar {
            width: 72px;
            height: 72px;
            border-radius: 16px;
        }

        h1 {
            font-size: clamp(1.8rem, 8vw, 2.5rem);
        }
    }
</style>
