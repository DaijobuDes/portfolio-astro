---
import ProfileHeader from './portfolio/ProfileHeader.astro';
import DetailList from './portfolio/DetailList.astro';
import ActionLink from './portfolio/ActionLink.astro';

const details = [
    {
        label: 'Focus',
        value: 'Backend Development, Systems Performance, & Network Engineering',
    },
    {
        label: 'Based in',
        value: 'Cebu, Philippines',
    },
    {
        label: 'Available for',
        value: 'Full-time Opportunities (Remote / Hybrid (Cebu City))',
    },
];
---

<div id="container">
    <main class="card" aria-label="Portfolio preview">
        <p class="eyebrow">Portfolio</p>
        <ProfileHeader
            avatarSrc="https://avatars.githubusercontent.com/u/38452446"
            avatarAlt="Portrait of Kate Aubrey Cellan"
            name="Kate Aubrey Cellan"
            subtitle="Software Developer • Homelabber • Hobbyist Security Researcher • Hardware Enthusiast • IoT Tinkerer"
        />
        <DetailList items={details} />

        <div class="actions">
            <ActionLink
                href="https://www.linkedin.com/in/kate-aubrey-cellan/"
                target="_blank"
                rel="noopener noreferrer"
                label="LinkedIn"
            />
            <ActionLink
                href="https://github.com/DaijobuDes"
                target="_blank"
                rel="noopener noreferrer"
                variant="secondary"
                label="Github"
            />
        </div>
    </main>
</div>

<style>
    :global(html, body) {
        margin: 0;
        min-height: 100%;
    }

    #container {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
        background:
            /* Change colors here */
            radial-gradient(circle at top, rgba(255, 255, 255, 0.18), transparent 35%),
            linear-gradient(135deg, #0f172a 0%, #111827 55%, #1f2937 100%);
    }

    .card {
        width: min(100%, 520px);
        padding: 32px;
        border-radius: 24px;
        background: rgba(15, 23, 42, 0.82);
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
        color: #f8fafc;
        backdrop-filter: blur(16px);
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        will-change: transform;
    }

    .card:hover {
        transform: translateY(-4px);
        border-color: rgba(255, 255, 255, 0.2);
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.42);
    }

    .eyebrow {
        margin: 0 0 12px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.78rem;
        color: #93c5fd;
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
    }
</style>
